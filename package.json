{
  "name": "@kud/gh-pr-comments",
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "bun src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target bun",
    "build:watch": "bun build src/index.tsx --outdir dist --target bun --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.2.0",
    "@opentui/react": "^0.2.0",
    "react": "19"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/node": "^20.0.0",
    "@types/react": "19",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
